# Required: Your Anthropic API key for Claude extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Mount a local folder so the app can browse your scans
# Mac/Linux example:  SCANS_PATH=/Users/you/Desktop/scans
# Windows example:    SCANS_PATH=C:\Users\you\Desktop\scans
SCANS_PATH=./scans

# Optional: Change the port (default 8000)
# PORT=8000

# Optional: Change the database password
# DB_PASSWORD=luftarchiv_dev
